	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="ConexionTorneoEsports"/>
	<queryString language="SQL">
		<![CDATA[SELECT 
    t.nombre AS torneo,
    e.nombre AS equipo,
    c.puntos,
    c.victorias,
    c.derrotas
FROM clasificaciones c
INNER JOIN equipos e ON c.id_equipo = e.id_equipo
INNER JOIN torneos t ON c.id_torneo = t.id_torneo
ORDER BY c.id_torneo, c.puntos DESC]]>
	</queryString>
