	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="ConexionTorneoEsports"/>
	<queryString language="SQL">
		<![CDATA[SELECT 
    v.genero AS genero_juego,
    v.nombre AS nombre_videojuego,
    t.nombre AS nombre_torneo,
    COUNT(i.id_inscripcion) AS total_inscritos
FROM torneos t
INNER JOIN videojuegos v ON t.id_videojuego = v.id_videojuego
LEFT JOIN inscripciones i ON i.id_torneo = t.id_torneo
GROUP BY v.genero, v.nombre, t.nombre, t.id_torneo
ORDER BY total_inscritos DESC]]>
	</queryString>
